# Provider: openrouter | openai | gemini
LLM_PROVIDER=openrouter

# OpenRouter (https://openrouter.ai) — single key for both LLM + embeddings
OPENROUTER_API_KEY=your-openrouter-key-here
# Optional: override default model (default: openai/gpt-4o-mini)
# OPENROUTER_MODEL=anthropic/claude-3.5-sonnet

# Direct OpenAI (only needed if LLM_PROVIDER=openai)
OPENAI_API_KEY=your-key-here

# Google Gemini (only needed if LLM_PROVIDER=gemini)
GOOGLE_API_KEY=your-key-here
